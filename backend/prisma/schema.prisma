generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  fullName    String
  role        String
  provider    String?
  providerId  String?
  createdAt   DateTime @default(now())
}